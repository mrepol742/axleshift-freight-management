{
    "private": true,
    "type": "module",
    "scripts": {
        "production": "concurrently \"npm run env\" \"npm run gemini\" \"npm run prompt\" \"npm run start\"",
        "start": "node src/index",
        "test": "mocha --timeout 10000 --exit",
        "dev": "nodemon --ext js --ignore '*.json' --trace-deprecation --trace-warnings src/index",
        "pretty": "prettier --write .",
        "env": "[ ! -f .env ] && cp .env.example .env",
        "pm2": "pm2 start ecosystem.config.cjs",
        "pm2:restart": "pm2 restart all --update-env",
        "db:seed": "node src/models/seeders/DatabaseSeeders.js",
        "db:wipe": "node src/models/migration/DatabaseWipe.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1015.0",
        "@aws-sdk/lib-storage": "^3.1015.0",
        "@aws-sdk/s3-request-presigner": "^3.1015.0",
        "@sentry/node": "^10.45.0",
        "@sentry/profiling-node": "^10.45.0",
        "archiver-zip-encrypted": "^2.0.0",
        "axios": "^1.13.6",
        "boolean-pro": "^1.0.0",
        "compression": "^1.8.1",
        "concurrently": "^9.2.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-mongo-sanitize": "^2.2.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "is-spaghetti-code": "^1.0.1",
        "mongodb": "^7.1.1",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.3",
        "pdf-lib": "^1.17.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "qs": "^6.15.0",
        "ratelimit-header-parser": "^0.1.0",
        "ua-parser-js": "^2.0.9",
        "useragent": "^2.3.0",
        "xendit-node": "^7.0.0",
        "xlsx": "^0.18.5",
        "zxcvbn": "^4.4.2"
    },
    "devDependencies": {
        "chai": "^6.2.2",
        "jsdom": "^29.0.1",
        "mocha": "^11.7.5",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2"
    }
}
